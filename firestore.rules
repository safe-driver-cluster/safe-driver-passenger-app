rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isValidPhoneNumber(phone) {
      return phone.matches('^\\+94[1-9][0-9]{8}$');
    }
    
    function hasValidUserData() {
      return 'phoneNumber' in request.resource.data &&
             'isVerified' in request.resource.data &&
             'createdAt' in request.resource.data;
    }
    
    // Users collection - users can only access their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow create: if isAuthenticated() && 
                       isOwner(userId) && 
                       hasValidUserData() &&
                       isValidPhoneNumber(request.resource.data.phoneNumber);
      
      // User preferences subcollection
      match /preferences/{document=**} {
        allow read, write: if isOwner(userId);
      }
      
      // User stats subcollection
      match /stats/{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Passenger profile documents - users can only access their own profile
    match /passenger_details/{userId} {
      allow read, create, update, delete: if isOwner(userId);
    }
    
    // OTP verifications - only Cloud Functions can write, users cannot directly access
    match /otp_verifications/{verificationId} {
      allow read, write: if false; // Only Cloud Functions can access
    }
    
    // Feedback collection - users can create, read own feedback, and admins manage
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated() && 
                       'userId' in request.resource.data &&
                       request.resource.data.userId == request.auth.uid &&
                       'timestamp' in request.resource.data &&
                       'status' in request.resource.data;
      
      // Users can read their own feedback
      allow read: if isAuthenticated() && 
                     (request.resource.data.userId == request.auth.uid ||
                      request.auth.token.admin == true);
      
      // Admins can read all feedback
      allow read: if isAuthenticated() && request.auth.token.admin == true;
      
      // Users can update their own feedback status
      allow update: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Admins can delete feedback
      allow delete: if isAuthenticated() && request.auth.token.admin == true;
      
      // Audit logs subcollection
      match /auditLogs/{auditId} {
        allow read: if isAuthenticated() && 
                       (resource.data.userId == request.auth.uid ||
                        request.auth.token.admin == true);
        allow write: if isAuthenticated() && request.auth.token.admin == true;
      }
    }
    
    // Feedback audit logs
    match /feedback_audit_logs/{auditId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.token.admin == true;
    }
    
    // Buses collection - public read access for authenticated users
    match /buses/{busId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin/system writes via Cloud Functions
      
      // Bus real-time data subcollection
      match /realtime/{document=**} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // Vehicles collection - public read access for authenticated users
    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin/system writes via Cloud Functions
    }
    
    // Drivers collection - public read access for authenticated users
    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin/system writes via Cloud Functions
    }
    
    // Routes collection - public read access
    match /routes/{routeId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin/system writes
      
      // Route stops subcollection
      match /stops/{document=**} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }
    
    // Safety alerts - read-only for authenticated users
    match /safety_alerts/{alertId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only system writes
    }

    // Map hazards - read-only for authenticated users
    match /hazards/{hazardId} {
      allow read: if isAuthenticated();
      allow write: if false; // Managed by admin/system
    }
    
    // Emergency contacts - users can only access their own
    match /emergency_contacts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // SOS data - contacts and event logs are stored outside the users collection
    match /SOS/{userId} {
      allow read, write: if isOwner(userId);

      match /sos_contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }

      match /sos_events/{eventId} {
        allow read, create: if isOwner(userId);
        allow update, delete: if false;
      }
    }
    
    // Journeys - users can only access their own journeys
    match /journeys/{journeyId} {
      allow read, write: if isAuthenticated() && 
                            request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && 
                       request.auth.uid == request.resource.data.userId;
    }
    
    // Feedback - users can create and read their own feedback
    match /feedback/{feedbackId} {
      allow read, write: if isAuthenticated() && 
                            request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && 
                       request.auth.uid == request.resource.data.userId;
    }
    
    // Support conversations - users can only access their own conversation and messages
    match /support_conversations/{userId} {
      allow read, write: if isOwner(userId);
      
      // Messages subcollection - users can read all messages in their conversation
      // and create new messages
      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && 
                         isAuthenticated() &&
                         'createdAt' in request.resource.data &&
                         'text' in request.resource.data &&
                         'senderId' in request.resource.data;
      }
    }
    
    // Notifications - users can only access their own
    match /notifications/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only system writes notifications
      
      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId) && 
                         // Only allow updating read status
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      }
    }
    
    // Analytics and logs - no direct access (system only)
    match /analytics/{document=**} {
      allow read, write: if false;
    }
    
    match /audit_logs/{document=**} {
      allow read, write: if false;
    }
    
    // System configuration - read-only for authenticated users
    match /system_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // Default deny rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
